<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.capstone.controller.ConfirmationController">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Order Confirmed!" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: green;"/>

    <Label fx:id="orderIdLabel"/>
    <Label fx:id="statusLabel"/>
    <Label fx:id="totalLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Button text="Cancel Order" onAction="#onCancelOrderClick" style="-fx-text-fill: red;"/>
    <Label fx:id="cancelMessageLabel"/>

    <Button text="Back to Restaurants" onAction="#onBackToHomeClick"/>
</VBox>
