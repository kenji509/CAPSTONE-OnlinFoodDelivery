<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="12" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.capstone.controller.RiderRegisterController">
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Create Rider Account" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <TextField fx:id="nameField" promptText="Full Name"/>
    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password"/>
    <TextField fx:id="contactField" promptText="Contact Number"/>
    <TextField fx:id="vehicleField" promptText="Vehicle Type (e.g. Motorcycle)"/>
    <Button text="Register" onAction="#onRegisterButtonClick"/>
    <Hyperlink text="Already have an account? Login" onAction="#onGoToLoginClick"/>
    <Label fx:id="messageLabel"/>
</VBox>