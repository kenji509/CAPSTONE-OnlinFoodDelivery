<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.capstone.RiderDashboardController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Rider Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label text="Available Orders"/>

    <ListView fx:id="ordersListView" prefHeight="300"/>

    <Button text="Accept Selected Order" onAction="#onAcceptOrderClick"/>
    <Label fx:id="statusLabel"/>
</VBox>